# Entorno de la aplicación.
ENV=development
# Si se desea habilitar la documentación de la API.
DOCS_ENABLED=false
# Orígenes permitidos para CORS.
CORS_ORIGINS=
# Si se desea habilitar las cookies seguras.
COOKIES_SECURE=false
# SameSite de las cookies.
COOKIES_SAMESITE=lax
# Host de la base de datos.
DB_HOST=
# Puerto de la base de datos.
DB_PORT=
# Usuario de la base de datos.
DB_USER=
# Contraseña de la base de datos.
DB_PASSWORD=
# Nombre de la base de datos.
DB_NAME=moderacionbd
# Tamaño máximo del pool de conexiones (mínimo 1).
DB_POOL_SIZE=5
# Timeout (segundos) para establecer una conexión al servidor (mínimo 1).
DB_CONNECTION_TIMEOUT=10